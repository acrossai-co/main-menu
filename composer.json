{
    "name": "acrossai-co/main-menu",
    "description": "AcrossAI Admin Dashboard parent menu and shared Settings page with SlotFill extension points.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "automattic/jetpack-autoloader": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "AcrossAI_Main_Menu\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "automattic/jetpack-autoloader": true
        }
    },
    "extra": {
        "autoloader-suffix": "AcrossAI_Main_Menu",
        "wp-requires": "6.0"
    }
}
